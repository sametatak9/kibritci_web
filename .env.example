# Firebase — kibritci-erp projesine bağlamak için Firebase Console > Project settings > Web app
# Render Dashboard > kibritci-erp > Environment bölümüne aynı değerleri ekleyin.
# Tanımlı değilse firebase-applet-config.json kullanılır (şu an: learned-spark-25xj8).
#
# GÜVENLİ GEÇİŞ SIRASI (canlı site bozulmasın):
# 1. npm run migrate:firestore:audit     → mevcut veri sayımı (canlıya dokunmaz)
# 2. firebase-target.config.json doldur  → örnek: firebase-target.config.example.json
# 3. npm run migrate:firestore:dry-run   → simülasyon
# 4. npm run migrate:firestore           → kopyala (Render hâlâ eski projede)
# 5. npm run migrate:firestore:verify    → sayım eşleşmesi
# 6. Yerel test (.env ile kibritci-erp)
# 7. Render VITE_FIREBASE_* → Manual Deploy
# Geri alma: Render env sil → deploy → learned-spark-25xj8

VITE_FIREBASE_PROJECT_ID=kibritci-erp
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=kibritci-erp.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=kibritci-erp.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# kibritci-erp için boş bırakın → (default). Eski AI Studio DB: ai-studio-84f7bd62-...
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

GEMINI_API_KEY=
