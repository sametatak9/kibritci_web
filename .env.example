# Firebase — kibritci-erp projesine bağlamak için Firebase Console > Project settings > Web app
# Render Dashboard > kibritci-erp > Environment bölümüne aynı değerleri ekleyin.
# Tanımlı değilse firebase-applet-config.json kullanılır (şu an: learned-spark-25xj8).

VITE_FIREBASE_PROJECT_ID=kibritci-erp
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=kibritci-erp.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=kibritci-erp.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Standart Firestore için boş bırakın veya (default). AI Studio adlı DB için ID yazın.
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

GEMINI_API_KEY=
